# Local development works with none of these set.

# Model reviews via the Vercel AI SDK and OpenAI. Without it, a
# deterministic demo reviewer runs and the UI says so.
OPENAI_API_KEY=

# Optional model override. Defaults to gpt-5.4-mini.
OPENAI_MODEL=

# Secret for signing session cookies. Required when DEMO_AUTH=1 in production.
AUTH_SECRET=

# Persona sign-in is local-only by default. Set DEMO_AUTH=1, AUTH_SECRET, and
# APP_ACCESS_CODE intentionally if you deploy the persona demo.
DEMO_AUTH=

# If set, sign-in requires this shared access code.
APP_ACCESS_CODE=

# Public demo: set to 1 (with DEMO_AUTH=1) to let anyone sign in as a persona
# with no access code. Visitors can write data, so pair it with ephemeral
# storage (no DATABASE_URL). Reviews are forced onto the free deterministic
# heuristic pipeline even if OPENAI_API_KEY is set.
DEMO_PUBLIC=

# Postgres connection string (Neon, Vercel Postgres, or any other provider).
# When set, the app uses Postgres instead of local SQLite.
# Example: postgres://user:pass@host:5432/dbname
DATABASE_URL=

# Set to 0 to skip seeding the demo documents on first run.
SEED_DEMO_DATA=
