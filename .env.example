# All optional — the app runs in demo mode with none of these set.

# Model reviews via the Vercel AI SDK (claude-opus-4-8). Without it, a
# deterministic demo reviewer runs and the UI says so.
ANTHROPIC_API_KEY=

# Secret for signing session cookies. Set a real value in production.
AUTH_SECRET=

# If set, sign-in requires this shared access code (gates a public deploy).
APP_ACCESS_CODE=

# Durable storage on Vercel (Upstash Redis via the Vercel Marketplace).
# Locally a JSON file in .data/ is used instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Set to 0 to skip seeding the demo documents on first run.
SEED_DEMO_DATA=
