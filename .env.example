# Local development works with none of these set.

# Model reviews via the Vercel AI SDK and OpenAI. Without it, a
# deterministic demo reviewer runs and the UI says so.
OPENAI_API_KEY=

# Optional model override. Defaults to gpt-5.4-mini.
OPENAI_MODEL=

# Secret for signing session cookies. Required when DEMO_AUTH=1 in production.
AUTH_SECRET=

# Persona sign-in is local-only by default. Set DEMO_AUTH=1, AUTH_SECRET, and
# APP_ACCESS_CODE intentionally if you deploy the persona demo.
DEMO_AUTH=

# If set, sign-in requires this shared access code.
APP_ACCESS_CODE=

# Durable storage on Vercel (Upstash Redis via the Vercel Marketplace).
# Locally a JSON file in .data/ is used instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Set to 0 to skip seeding the demo documents on first run.
SEED_DEMO_DATA=
